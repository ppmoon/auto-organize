# 123云盘 WebDAV Configuration
# WebDAV URL for 123pan (typically https://webdav.123pan.com)
WEBDAV_URL=https://webdav.123pan.com

# Your 123pan account credentials
WEBDAV_USERNAME=your_123pan_username
WEBDAV_PASSWORD=your_123pan_password

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key

# Optional: Custom OpenAI base URL (for proxies or alternative providers)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
